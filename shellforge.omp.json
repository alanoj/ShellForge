{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "shell_integration": true,
  "palette": {
    "git_branch_divergence": "p:terminal_pink",
    "git_changes_pending": "p:terminal_blue",
    "git_commits_ahead": "p:terminal_brightgray",
    "git_commits_behind": "p:terminal_lightblue",
    "main_background": "#1f2335",
    "secondary_background": "#282e46",
    "terminal_blue": "#5DABF3",
    "terminal_cyan": "#5DC9F2",
    "terminal_bluegray": "#acb9e6",
    "terminal_brightgray": "#ced9ff",
    "terminal_error": "#CA5F71",
    "terminal_gray": "#AEA4BF",
    "terminal_green": "#49EF95",
    "terminal_lightblue": "#7386d0",
    "terminal_lightgray": "#cbcfe7",
    "terminal_lightteal": "#99E6B3",
    "terminal_pink": "#B86CB3",
    "terminal_red": "#CA5FA6",
    "tertiary_background": "#2d3654",
    "os_color": "#7386d0"
  },
  "var": {
    "dot": "\uf444",
    "git_branch_divergence": "<p:git_branch_divergence>\udb80\udc27</>",
    "git_changes_pending": "<p:git_changes_pending>\udb82\udd93</>",
    "git_commits_ahead": "<p:git_commits_ahead>\udb81\udf38</>",
    "git_commits_behind": "<p:git_commits_behind>\udb81\udf2f</>",
    "branch_identical_icon": "󰓦",
    "github": "https://github.com/alanoj/shelldrop"
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": false,
      "segments": [
        {
          "type": "battery",
          "style": "diamond",
          "foreground": "p:main_background",
          "background": "p:main_background",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "{{ if not .Error }}{{- if lt .Percentage 10 }}<p:terminal_error>\udb80\udc83</>{{- else if lt .Percentage 39 }}<p:terminal_pink>\udb80\udc7b</>{{- else if lt .Percentage 59 }}<p:terminal_lightgray>\udb80\udc7d</>{{- else if lt .Percentage 79 }}<p:terminal_bluegray>\udb80\udc7f</>{{- else if lt .Percentage 98 }}<p:terminal_lightblue>\udb80\udc81</>{{- else }}<p:terminal_blue>\udb80\udc79</>{{- end }}{{ end }}"
        },
        {
          "type": "root",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_pink",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "\udb82\udee2",
          "options": {
            "cache_duration": "none"
          }
        },
        {
          "type": "upgrade",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_brightgray",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "<f>\udb80\udd62</f>",
          "options": {
            "cache_duration": "168h"
          }
        },
        {
          "type": "session",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_bluegray",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "{{ if .SSHSession }}\udb82\udcc0{{ end }}"
        },
        {
          "type": "python",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_lightblue",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "\ue235 {{ .Full }}{{ if .WSL }} {{ base (dir (dir (dir (stat .Executable)))) }}{{ end }}",
          "options": {
            "cache_duration": "none",
            "fetch_version": true,
            "folder_name_fallback": false
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_blue",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "max_width": 109,
          "templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) (and (gt .Ahead 0) (gt .Behind 0)) (gt .Ahead 0) (gt .Behind 0) }}[{{ if or (.Working.Changed) (.Staging.Changed) }}{{.Var.git_changes_pending}}{{ end }}{{ if and (gt .Ahead 0) (gt .Behind 0) }}{{.Var.git_branch_divergence}}{{ end }}{{ if gt .Ahead 0 }}{{.Var.git_commits_ahead}}{{ end }}{{ if gt .Behind 0 }}{{.Var.git_commits_behind}}{{ end }}{{ if and (not (.Working.Changed)) (not (.Staging.Changed)) (eq .Ahead 0) (eq .Behind 0) }}{{ .Var.branch_identical_icon }}{{ end }}]{{ end }}",
            " {{ url .HEAD .UpstreamURL }}"
          ],
          "options": {
            "branch_icon": "\ue725 ",
            "branch_template": "{{ trunc 20 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          }
        },
        {
          "type": "executiontime",
          "style": "diamond",
          "background": "p:main_background",
          "foreground": "p:terminal_lightgray",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": "{{ .FormattedMs }}",
          "options": {
            "style": "austin",
            "threshold": 200
          }
        },
        {
          "type": "status",
          "style": "diamond",
          "background": "p:tertiary_background",
          "foreground": "p:terminal_bluegray",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:terminal_error{{ end }}"
          ],
          "template": "{{ if ne .Code 0 }}󱚡 {{ reason .Code }}{{ end }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "p:foreground",
          "template": "\u256d\u2500"
        },
        {
          "type": "os",
          "style": "diamond",
          "background": "p:main_background",
          "foreground": "p:os_color",
          "leading_diamond": "\ue0b6",
          "template": "{{ url .Icon .Var.github }} ",
          "options": {
            "macos": "\ue711",
            "windows": "\ue70f"
          }
        },
        {
          "type": "session",
          "style": "diamond",
          "foreground": "p:terminal_gray",
          "background": "p:main_background",
          "trailing_diamond": "\ue0b4",
          "template": "{{ if .SSHSession }}\ueba9{{ end }}{{ .HostName }}"
        },
        {
          "type": "git",
          "style": "diamond",
          "background": "p:secondary_background",
          "foreground": "p:terminal_blue",
          "trailing_diamond": "\ue0b4",
          "min_width": 110,
          "options": {
            "branch_icon": "<p:terminal_blue>\ue725</> ",
            "branch_template": "{{ trunc 20 .Branch }}",
            "fetch_status": true,
            "fetch_upstream_icon": true
          },
          "templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) (and (gt .Ahead 0) (gt .Behind 0)) (gt .Ahead 0) (gt .Behind 0) }}[{{ if or (.Working.Changed) (.Staging.Changed) }}{{.Var.git_changes_pending}}{{ end }}{{ if and (gt .Ahead 0) (gt .Behind 0) }}{{.Var.git_branch_divergence}}{{ end }}{{ if gt .Ahead 0 }}{{.Var.git_commits_ahead}}{{ end }}{{ if gt .Behind 0 }}{{.Var.git_commits_behind}}{{ end }}]{{ end }}",
            " <p:terminal_cyan>{{ .UpstreamIcon }}{{ url .HEAD .UpstreamURL }}</>"
          ]
        },
        {
          "type": "path",
          "style": "diamond",
          "background": "p:tertiary_background",
          "foreground": "p:terminal_bluegray",
          "trailing_diamond": "\ue0b4",
          "template": " {{ path .Path .Location }}",
          "options": {
            "folder_icon": "",
            "home_icon": "",
            "folder_separator_icon": "/",
            "max_depth": 2,
            "style": "agnoster_short",
            "cycle": [
              "p:terminal_brightgray",
              "p:terminal_bluegray"
            ],
            "cycle_folder_separator": true,
            "mapped_locations": {
              "re:(.*/Desktop).*": "\uf108",
              "re:(.*/Documents).*": "󱔗",
              "re:(.*/Documents/GitHub).*": "",
              "re:(.*/Developer).*": "",
              "re:(.*/Download[s]?).*": "",
              "re:(.*/Pictures).*": "",
              "re:(.*/Video[s]?).*": ""
            }
          }
        }
      ]
    },
    {
      "alignment": "right",
      "type": "prompt",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "background": "p:tertiary_background",
          "foreground": "p:terminal_gray",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "template": "{{ .CurrentDate | date .Format }}",
          "options": {
            "time_format": "3:04 PM"
          }
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:terminal_cyan",
          "style": "diamond",
          "leading_diamond": "\u2570\u2500",
          "template": " ",
          "type": "text"
        }
      ]
    }
  ],
  "secondary_prompt": {
    "template": "<d>\u279c </d>",
    "background": "transparent",
    "foreground": "p:os_color"
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:os_color",
    "template": "{{ if .Segments.Executiontime.Ms }}<p:main_background>\ue0b6</><p:terminal_lightgray,p:main_background>{{ .Segments.Executiontime.FormattedMs }}</><p:main_background>\ue0b4</>{{ end }}<p:main_background>\ue0b6</><p:terminal_gray,p:main_background>{{ .Segments.Time.CurrentDate | date .Segments.Time.Format }}</><p:main_background>\ue0b4</><p:terminal_blue>  </>",
    "filler": "<p:os_color><d> \u002d</d></>"
  },
  "upgrade": {
    "notice": true,
    "interval": "168h",
    "auto": false,
    "source": "cdn"
  }
}